  "keyFeatures": [
    "Electronic invoice XML generation and digital signing",
    "Document queries by CDC (Control Code)",
    "RUC (tax ID) validation and lookup",
    "Batch processing for multiple documents",
    "Event cancellation support",
    "Multi-tenant configuration",
    "SIFEN health monitoring",
    "Clean Architecture implementation"
  ],
  "publicApiSurface": [
    "POST /factura/xml/generar - Generate signed XML invoice",
    "POST /factura/async/recibe - Receive invoice asynchronously",
    "POST /consulta/de/xml - Query electronic document (XML)",
    "POST /consulta/de/json - Query electronic document (JSON)",
    "POST /consulta/ruc - Query RUC information",
    "POST /consulta/lote - Query batch",
    "POST /evento/cancelar - Cancel event",
    "GET /health/sifen/{env} - Check SIFEN health status"
  ]
